{% extends '_layout.twig' %}

{% block content %}

  {% include '_components/pageHero.twig' with {
    params: {
      img: "https://images.unsplash.com/photo-1508214751196-bcfd4ca60f91?w=1600&q=80",
      title: "Find Us",
      subTitle: "Online, In Person & Around Charlotte"
    }
  } %}

  {# Intro #}
  <section class="bg-white py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-hobeaux text-teal uppercase tracking-widest text-sm mb-2">Where we are</p>
      <h2 class="font-anton text-charcoal text-4xl sm:text-5xl mb-4">Ways to Get Your Paws on Our Treats</h2>
      <p class="font-hobeaux text-charcoal/60 text-base leading-relaxed">
        Whether you're local to Charlotte or shipping across the country, there's a way to get Charlie's Barkery treats to your dog. Here's everywhere you can find us.
      </p>
    </div>
  </section>

  {# Channels Overview #}
  <section class="bg-gray-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">

        {% set channels = [
          {
            icon: "🛍️",
            label: "Online Store",
            desc: "Order from anywhere in the US. We ship treats, cookies, and birthday cookie packages straight to your door.",
            cta: "Shop Now",
            href: "/shop",
            color: "bg-teal/10 text-teal"
          },
          {
            icon: "🌿",
            label: "Farmers Markets",
            desc: "Find us most weekends at markets across the Charlotte Metro. Meet us, bring your dog, and let them pick their treat.",
            cta: "See Markets",
            href: "#markets",
            color: "bg-bronze/10 text-bronze"
          },
          {
            icon: "🎉",
            label: "Events & Pop-Ups",
            desc: "We set up at dog festivals, brewery days, adoption events, and more. Check the events page for what's coming up.",
            cta: "See Events",
            href: "/events",
            color: "bg-charcoal/10 text-charcoal"
          },
          {
            icon: "🏪",
            label: "Consignment",
            desc: "A handful of dog-friendly shops in the Charlotte area carry our treats on their shelves year-round.",
            cta: "See Locations",
            href: "#consignment",
            color: "bg-teal/10 text-teal"
          }
        ] %}

        {% for channel in channels %}
          <div class="bg-white rounded-3xl p-8 flex flex-col gap-4 border border-gray-100 hover:border-teal transition-colors">
            <span class="text-4xl">{{ channel.icon }}</span>
            <div>
              <h3 class="font-anton text-charcoal text-xl mb-1">{{ channel.label }}</h3>
              <p class="font-hobeaux text-charcoal/60 text-sm leading-relaxed">{{ channel.desc }}</p>
            </div>
            <a
              href="{{ channel.href }}"
              class="font-hobeaux font-bold text-sm text-teal hover:text-bronze transition-colors self-start mt-auto"
            >{{ channel.cta }} →</a>
          </div>
        {% endfor %}

      </div>
    </div>
  </section>

  {# Farmers Markets #}
  <section id="markets" class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-12 items-center">

      <div class="flex flex-col gap-5">
        <p class="font-hobeaux text-teal uppercase tracking-widest text-sm">Our regulars</p>
        <h2 class="font-anton text-charcoal text-4xl leading-tight">Farmers Markets</h2>
        <p class="font-hobeaux text-charcoal/60 text-base leading-relaxed">
          These are the markets we show up to most consistently. Schedules can shift seasonally — follow us on Instagram for week-to-week updates before you make the trip.
        </p>

        {% set markets = [
          {
            name: "Matthews Community Farmers Market",
            schedule: "Sundays, year-round",
            location: "Matthews, NC",
            hours: "8:00 AM – 12:00 PM"
          },
          {
            name: "South End Farmers Market",
            schedule: "Saturdays, seasonal (spring–fall)",
            location: "Charlotte, NC",
            hours: "9:00 AM – 1:00 PM"
          },
          {
            name: "Waxhaw Farmers Market",
            schedule: "Sundays, seasonal",
            location: "Waxhaw, NC",
            hours: "8:00 AM – 12:00 PM"
          }
        ] %}

        <ul class="flex flex-col gap-4">
          {% for market in markets %}
            <li class="flex gap-4 items-start">
              <span class="w-2 h-2 rounded-full bg-teal shrink-0 mt-2"></span>
              <div>
                <p class="font-anton text-charcoal text-base">{{ market.name }}</p>
                <p class="font-hobeaux text-charcoal/50 text-sm">{{ market.schedule }} &middot; {{ market.hours }}</p>
                <p class="font-hobeaux text-charcoal/40 text-xs">{{ market.location }}</p>
              </div>
            </li>
          {% endfor %}
        </ul>

        <a
          href="https://instagram.com/charliesbarkery"
          target="_blank"
          rel="noopener"
          class="font-hobeaux font-bold bg-charcoal text-white px-8 py-3 rounded-full hover:bg-teal hover:text-charcoal transition-colors self-start mt-2"
        >
          Follow for Updates
        </a>
      </div>

      <div>
        <img
          src="https://images.unsplash.com/photo-1601758125946-6ec2ef64daf8?w=800&q=80"
          alt="Charlie's Barkery at a farmers market"
          class="rounded-3xl w-full h-[440px] object-cover"
        />
      </div>

    </div>
  </section>

  {# Consignment Locations #}
  <section id="consignment" class="bg-gray-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="max-w-2xl mb-10">
        <p class="font-hobeaux text-teal uppercase tracking-widest text-sm mb-2">On the shelf near you</p>
        <h2 class="font-anton text-charcoal text-4xl leading-tight">Find Us In Store</h2>
        <p class="font-hobeaux text-charcoal/60 text-base leading-relaxed mt-3">
          These Charlotte-area shops carry Charlie's Barkery treats year-round. Stop in and tell them Charlie sent you.
        </p>
      </div>

      {% set stores = [
        {
          name: "The Biscuit Bar",
          neighborhood: "Dilworth",
          city: "Charlotte, NC",
          note: "Dog boutique carrying our full treat lineup."
        },
        {
          name: "Wags & Whiskers",
          neighborhood: "Plaza Midwood",
          city: "Charlotte, NC",
          note: "Rotating seasonal selection of our cookies and treats."
        },
        {
          name: "Canine Couture",
          neighborhood: "Myers Park",
          city: "Charlotte, NC",
          note: "Our treats alongside premium dog goods."
        },
        {
          name: "The Dog Stop – Matthews",
          neighborhood: "Matthews",
          city: "Matthews, NC",
          note: "Full treat lineup available daily."
        }
      ] %}

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {% for store in stores %}
          <div class="bg-white rounded-3xl p-6 flex flex-col gap-2 border border-gray-100 hover:border-teal transition-colors">
            <div class="w-10 h-10 rounded-full bg-bronze/10 flex items-center justify-center shrink-0 mb-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-bronze" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <h4 class="font-anton text-charcoal text-lg">{{ store.name }}</h4>
            <p class="font-hobeaux text-charcoal/50 text-xs">{{ store.neighborhood }} &middot; {{ store.city }}</p>
            <p class="font-hobeaux text-charcoal/60 text-sm leading-relaxed mt-1">{{ store.note }}</p>
          </div>
        {% endfor %}
      </div>

      <p class="font-hobeaux text-charcoal/40 text-sm mt-8">
        Interested in carrying Charlie's Barkery in your store?
        <a href="{{ url('contact') }}?subject=Wholesale" class="text-teal hover:text-bronze transition-colors">Get in touch →</a>
      </p>

    </div>
  </section>

  {# Online Store Banner #}
  <section class="bg-charcoal py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-8">
      <div>
        <h2 class="font-anton text-white text-4xl sm:text-5xl leading-tight">Not in Charlotte?</h2>
        <p class="font-hobeaux text-white/70 text-base mt-3 max-w-xl leading-relaxed">
          No worries — we ship treats, cookies, and birthday packages nationwide. Your dog deserves fresh-baked goods no matter where you live.
        </p>
      </div>
      <a
        href="{{ url('shop') }}"
        class="font-hobeaux font-bold bg-teal text-charcoal px-10 py-4 rounded-full hover:bg-white transition-colors shrink-0 text-lg"
      >
        Shop Online
      </a>
    </div>
  </section>

{% endblock %}
