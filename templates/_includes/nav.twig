<nav class="bg-white shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      {# Logo #}
      <a href="{{ siteUrl }}" class="flex items-center gap-2">
        <span class="text-charcoal text-xl tracking-tight font-anton">Charlie's Barkery</span>
      </a>

      {# Desktop Nav #}
      <ul class="hidden md:flex items-center gap-8 text-charcoal font-medium">
        <li><a href="{{ url('shop') }}" class="hover:text-teal transition-colors">Shop</a></li>
        <li><a href="{{ url('about') }}" class="hover:text-teal transition-colors">About</a></li>
        <li><a href="{{ url('find-us') }}" class="hover:text-teal transition-colors">Find Us</a></li>
        <li><a href="{{ url('contact') }}" class="hover:text-teal transition-colors">Contact</a></li>
      </ul>

      {# Cart + Mobile Toggle #}
      <div class="flex items-center gap-4">
        <a href="{{ url('shop/cart') }}" class="relative text-charcoal hover:text-teal transition-colors" aria-label="Cart">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.5 6h13" />
          </svg>
          {% set cartCount = craft.commerce.carts.cart.totalQty ?? 0 %}
          {% if cartCount > 0 %}
            <span class="absolute -top-2 -right-2 bg-teal text-white text-xs rounded-full h-4 w-4 flex items-center justify-center">{{ cartCount }}</span>
          {% endif %}
        </a>

        {# Mobile menu button #}
        <button
          id="mobile-menu-toggle"
          class="md:hidden text-charcoal hover:text-teal transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

    </div>
  </div>

  {# Mobile Menu #}
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100">
    <ul class="flex flex-col px-4 py-3 gap-3 text-charcoal font-medium">
      <li><a href="{{ url('shop') }}" class="block py-2 hover:text-teal transition-colors">Shop</a></li>
      <li><a href="{{ url('about') }}" class="block py-2 hover:text-teal transition-colors">About</a></li>
      <li><a href="{{ url('find-us') }}" class="block py-2 hover:text-teal transition-colors">Find Us</a></li>
      <li><a href="{{ url('contact') }}" class="block py-2 hover:text-teal transition-colors">Contact</a></li>
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!open));
  });
</script>
