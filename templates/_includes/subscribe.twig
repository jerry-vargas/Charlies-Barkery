{% set subscribeBlock = block is defined ? block.subscribeblock : null %}

{# Set default values #}
{% set params = {
    theme: subscribeBlock.sectionThemeBackground.label ?? 'white',
    eyebrow: subscribeBlock.eyebrow ?? '',
    header: subscribeBlock.header ?? '',
    content: subscribeBlock.content ?? '',
    form: subscribeBlock.form.one() ?? null
}|merge(params|default({})) %}

{% set themes = {
    charcoal: {
        sectionBg: 'bg-charcoal',
        eyebrowColor: 'text-teal',
        headingColor: 'text-white',
        bodyColor: 'text-teal',
        formBg: 'bg-white/50',
        formBorder: 'border border-white/10'
    },
    bronze: {
        sectionBg: 'bg-bronze',
        eyebrowColor: 'text-white/70',
        headingColor: 'text-white',
        bodyColor: 'text-white/80',
        formBg: 'bg-white/10',
        formBorder: 'border border-white/20'
    },
    teal: {
        sectionBg: 'bg-teal',
        eyebrowColor: 'text-charcoal/70',
        headingColor: 'text-charcoal',
        bodyColor: 'text-charcoal/70',
        formBg: 'bg-white',
        formBorder: ''
    },
    white: {
        sectionBg: 'bg-white',
        eyebrowColor: 'text-teal',
        headingColor: 'text-charcoal',
        bodyColor: 'text-charcoal/70',
        formBg: 'bg-gray-50',
        formBorder: 'border border-charcoal/10'
    }
} %}

{% set theme = themes[params.theme|lower] ?? themes['white'] %}
{% set subscribeFormThemeConfig = craft.app.config.getConfigFromFile('formie-subscribe-theme') %}

<section id="join-the-pack" class="{{ theme.sectionBg }}">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 grid md:grid-cols-2 gap-12 items-center">
    <div>
      {% if params.eyebrow %}
        <p class="font-hobeaux {{ theme.eyebrowColor }} uppercase tracking-widest text-sm mb-2">{{ params.eyebrow }}</p>
      {% endif %}

      {% if params.header %}
        <h2 class="font-anton {{ theme.headingColor }} text-4xl sm:text-5xl leading-tight mb-4">
          {{ params.header }}
        </h2>
      {% endif %}

      {% if params.content %}
        <p class="font-hobeaux {{ theme.bodyColor }} text-base leading-relaxed">
          {{ params.content }}
        </p>
      {% endif %}
    </div>

    <div class="{{ theme.formBg }} {{ theme.formBorder }} rounded-3xl p-8 shadow-sm">
      {% if params.form %}
        {{ craft.formie.renderForm(params.form, {
            themeConfig: subscribeFormThemeConfig
        }) }}
      {% endif %}
    </div>
  </div>
</section>
