{% set params = {
    theme: block.splitSectionBlock.color.value ?? 'white',
    imageRight: block.splitSectionBlock.imageRight ?? false,
    img: block.splitSectionBlock.images.one() ?? false,
    eyebrow: block.splitSectionBlock.eyebrow ?? false,
    heading: block.splitSectionBlock.heading ?? false,
    richTextEditor: block.splitSectionBlock.richTextEditor ?? false,
    badge: block.splitSectionBlock.badge ?? false,
    badgeOverlay: block.splitSectionBlock.badgeOverlay ?? false,
    badgeText: block.splitSectionBlock.badgeText ?? false,
    badgeSubText: block.splitSectionBlock.badgeSubText ?? false
}|merge(params|default({})) %}

{% set themes = {
    white: {
        sectionBg: 'bg-white',
        eyebrowColor: 'text-teal',
        headingColor: 'text-charcoal',
        bodyColor: 'text-charcoal/70'
    },
    charcoal: {
        sectionBg: 'bg-charcoal',
        eyebrowColor: 'text-teal',
        headingColor: 'text-white',
        bodyColor: 'text-white/70'
    },
    teal: {
        sectionBg: 'bg-teal',
        eyebrowColor: 'text-white/70',
        headingColor: 'text-white',
        bodyColor: 'text-white/80'
    },
    bronze: {
        sectionBg: 'bg-bronze',
        eyebrowColor: 'text-white/70',
        headingColor: 'text-white',
        bodyColor: 'text-white/70'
    }
} %}

{% set theme = themes[params.theme] ?? themes['white'] %}

<section class="{{ theme.sectionBg }} py-20 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-12 items-center">
        {# ——— Image ——— #}
        {% set imageCol %}
            <div class="relative {% if params.badge and params.badgeOverlay %}h-[420px]{% endif %}">
                <img
                    src="https://images.unsplash.com/photo-1606313564200-e75d5e30476c?w=800&q=80"
                    alt="NEED TO CONFIGURE"
                    class="rounded-3xl w-full h-[420px] object-cover {% if params.badge and params.badgeOverlay %}absolute inset-0{% endif %}"
                />
                {# Overlay gradient + frosted badge #}
                {% if params.badge and params.badgeOverlay %}
                    <div class="absolute inset-0 rounded-3xl bg-gradient-to-t from-charcoal/60 to-transparent"></div>
                    <div class="absolute bottom-5 left-5 right-5 bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl px-5 py-4">
                        <p class="font-anton text-white text-lg">{{ params.badgeText }}</p>
                        {% if params.badgeSubText %}
                            <p class="font-hobeaux text-white/60 text-sm mt-0.5">{{ params.badgeSubText }}</p>
                        {% endif %}
                    </div>
                {% endif %}

                {# Corner badge #}
                {% if params.badge and not params.badgeOverlay %}
                    <div class="absolute -bottom-5 -right-5 bg-bronze text-white font-anton text-lg px-6 py-4 rounded-2xl shadow-lg hidden sm:block">
                        {{ params.badgeText }}
                    </div>
                {% endif %}
            </div>
        {% endset %}

        {# ——— Copy ——— #}
        {% set copyCol %}
            <div class="flex flex-col items-start gap-5">
                {% if params.eyebrow %}
                    <p class="font-hobeaux {{ theme.eyebrowColor }} uppercase tracking-widest text-sm">{{ params.eyebrow }}</p>
                {% endif %}

                {% if params.heading %}
                    <h2 class="font-anton {{ theme.headingColor }} text-4xl sm:text-5xl leading-tight">{{ params.heading }}</h2>
                {% endif %}

                {% if params.richTextEditor %}
                    <div class="font-hobeaux {{ theme.bodyColor }} text-base leading-relaxed [&_ul]:flex [&_ul]:flex-col [&_ul]:gap-2 [&_ul]:text-sm [&_li]:flex [&_li]:items-center [&_li]:gap-2 [&_li]:before:content-['✓'] [&_li]:before:text-teal">
                        {{ params.richTextEditor }}
                    </div>
                {% endif %}
            </div>
        {% endset %}

        {# ——— Order ——— #}
        {% if (params.imageRight == 0) %}
            {{ imageCol }}
            {{ copyCol }}
        {% else %}
            {{ copyCol }}
            {{ imageCol }}
        {% endif %}
    </div>
</section>
