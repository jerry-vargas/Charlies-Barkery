{# Set default values #}
{% set params = {
    eyebrowText: block.contactBlock.eyebrowText ?? '',
    header: block.contactBlock.header ?? '',
    copy: block.contactBlock.copy ?? '',
    formCallOut: block.contactBlock.formCallOut ?? '',
    form: block.contactBlock.form.one() ?? '',
    contactMatrix: block.contactBlock.contactMatrix.all() ?? []
}|merge(params|default({})) %}

<section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-16 items-start">

        {# Left: Info #}
        <div class="flex flex-col gap-10">

            <div>
                {% if params.eyebrowText is defined and params.eyebrowText %}
                    <p class="font-hobeaux text-teal uppercase tracking-widest text-sm mb-3">{{ params.eyebrowText }}</p>
                {% endif %}
                {% if params.header is defined and params.header %}
                    <h2 class="font-anton text-charcoal text-4xl leading-tight mb-4">{{ params.header }}</h2>
                {% endif %}
                {% if params.copy is defined and params.copy %}
                    <p class="font-hobeaux text-charcoal/60 text-base leading-relaxed">{{ params.copy }}</p>
                {% endif %}
            </div>

            {# Contact Details #}
            {% if params.contactMatrix is defined and params.contactMatrix %}
                <div class="flex flex-col gap-6">
                    {% for detail in params.contactMatrix %}
                        <div class="flex items-start gap-4">
                            <div class="bg-teal/10 rounded-2xl w-12 h-12 flex items-center justify-center shrink-0 text-xl">
                                {{ detail.icon }}
                            </div>
                            <div>
                                <p class="font-anton text-charcoal text-lg">{{ detail.title }} </p>
                                {% if detail.subTitle %}
                                    <p class="font-hobeaux text-charcoal/60 text-sm">{{ detail.subTitle }}</p>
                                {% endif %}
                                {% if detail.copy %}
                                    <p class="font-hobeaux text-charcoal/40 text-xs mt-0.5">{{ detail.copy }}</p>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            {# Socials #}
            {% if params.socials is defined and params.socials %}
                <div>
                    <p class="font-hobeaux text-charcoal/40 uppercase tracking-widest text-xs mb-3">Follow us</p>
                    <div class="flex gap-4">
                        {% for social in params.socials %}
                            <a href="{{ social.url }}" target="_blank" rel="noopener"
                               class="font-hobeaux text-sm text-charcoal/60 hover:text-teal transition-colors flex items-center gap-2">
                                <svg class="h-5 w-5">
                                    <use href="#{{ social.handle }}"></use>
                                </svg>
                                {{ social.label }}
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>

        {# Right: Formie Form #}
        <div class="bg-gray-50 rounded-3xl p-8">
            {% if params.formCallOut is defined and params.formCallOut %}
                <h3 class="font-anton text-charcoal text-2xl mb-6">{{ params.formCallOut }}</h3>
            {% endif %}
            {% if params.form %}
                {{ craft.formie.renderForm(params.form) }}
            {% endif %}
        </div>
    </div>
</section>