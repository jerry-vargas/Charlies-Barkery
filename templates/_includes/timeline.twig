{% set params = {
    theme: block.timelineBlock.timeline.label ?? 'white',
    eyebrowText: block.timelineBlock.eyebrowText ?? '',
    header: block.timelineBlock.header ?? '',
    timelineMatrix: block.timelineBlock.timelineMatrix.all() ?? []
}|merge(params|default({})) %}

<section class="bg-white py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
            <p class="font-hobeaux text-teal uppercase tracking-widest text-sm mb-2">How we got here</p>
            <h2 class="font-anton text-charcoal text-4xl sm:text-5xl">The Journey</h2>
        </div>
        <div class="flex flex-col gap-0">
            {% for timeline in params.timelineMatrix %}
                <div class="flex gap-6 group">
                    <div class="flex flex-col items-center">
                        <div class="w-4 h-4 rounded-full bg-teal mt-1.5 shrink-0 group-first:mt-1"></div>
                        {% if not loop.last %}
                            <div class="w-0.5 bg-gray-200 grow mt-1"></div>
                        {% endif %}
                    </div>
                    <div class="pb-10">
                        <p class="font-anton text-teal text-lg">{{ timeline.title }}</p>
                        <h3 class="font-anton text-charcoal text-2xl mt-0.5">{{ timeline.event }}</h3>
                        <p class="font-hobeaux text-charcoal/60 text-sm leading-relaxed mt-2">{{ timeline.eventDetails }}</p>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</section>
