{#
  Contact Section
  ---------------
  params:
    eyebrow       (string)  — small label above heading
    heading       (string)  — main heading
    description   (string)  — body copy
    details       (array)   — contact detail items:
                              { icon, label, value, href (optional), note (optional) }
    socials       (array)   — social links: { handle, label, url }
    formTitle     (string)  — heading above the form
    formHandle    (string)  — Formie form handle
#}

<section class="bg-white py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-16 items-start">

    {# Left: Info #}
    <div class="flex flex-col gap-10">

      <div>
        {% if params.eyebrow is defined and params.eyebrow %}
          <p class="font-hobeaux text-teal uppercase tracking-widest text-sm mb-3">{{ params.eyebrow }}</p>
        {% endif %}
        {% if params.heading is defined and params.heading %}
          <h2 class="font-anton text-charcoal text-4xl leading-tight mb-4">{{ params.heading }}</h2>
        {% endif %}
        {% if params.description is defined and params.description %}
          <p class="font-hobeaux text-charcoal/60 text-base leading-relaxed">{{ params.description }}</p>
        {% endif %}
      </div>

      {# Contact Details #}
      {% if params.details is defined and params.details %}
        <div class="flex flex-col gap-6">
          {% for detail in params.details %}
            <div class="flex items-start gap-4">
              <div class="bg-teal/10 rounded-2xl w-12 h-12 flex items-center justify-center shrink-0 text-xl">
                {{ detail.icon }}
              </div>
              <div>
                <p class="font-anton text-charcoal text-lg">{{ detail.label }}</p>
                {% if detail.href is defined and detail.href %}
                  <a href="{{ detail.href }}" class="font-hobeaux text-charcoal/60 text-sm hover:text-teal transition-colors">{{ detail.value }}</a>
                {% else %}
                  <p class="font-hobeaux text-charcoal/60 text-sm">{{ detail.value }}</p>
                {% endif %}
                {% if detail.note is defined and detail.note %}
                  <p class="font-hobeaux text-charcoal/40 text-xs mt-0.5">{{ detail.note }}</p>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}

      {# Socials #}
      {% if params.socials is defined and params.socials %}
        <div>
          <p class="font-hobeaux text-charcoal/40 uppercase tracking-widest text-xs mb-3">Follow us</p>
          <div class="flex gap-4">
            {% for social in params.socials %}
              <a href="{{ social.url }}" target="_blank" rel="noopener" class="font-hobeaux text-sm text-charcoal/60 hover:text-teal transition-colors flex items-center gap-2">
                <svg class="h-5 w-5"><use href="#{{ social.handle }}"></use></svg>
                {{ social.label }}
              </a>
            {% endfor %}
          </div>
        </div>
      {% endif %}

    </div>

    {# Right: Formie Form #}
    <div class="bg-gray-50 rounded-3xl p-8">
      {% if params.formTitle is defined and params.formTitle %}
        <h3 class="font-anton text-charcoal text-2xl mb-6">{{ params.formTitle }}</h3>
      {% endif %}
      {% if params.formHandle is defined and params.formHandle %}
{#        {{ craft.formie.renderForm(params.formHandle) }}#}

{# Form - placholder for now.. #}
{#        <h3 class="font-anton text-charcoal text-2xl mb-6">Send Us a Message</h3>#}
        <form method="post" accept-charset="UTF-8" novalidate>
          {{ csrfInput() }}
          <input type="hidden" name="action" value="contact-form/send">

          <div class="flex flex-col gap-5">

            <div class="grid sm:grid-cols-2 gap-4">
              <div class="flex flex-col gap-1">
                <label for="contact-name" class="font-hobeaux text-charcoal text-sm font-bold">Your Name</label>
                <input
                    id="contact-name"
                    type="text"
                    name="fromName"
                    placeholder="Jane Smith"
                    required
                    class="font-hobeaux border border-gray-200 bg-white rounded-xl px-4 py-3 text-sm text-charcoal placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal"
                />
              </div>
              <div class="flex flex-col gap-1">
                <label for="contact-email" class="font-hobeaux text-charcoal text-sm font-bold">Email Address</label>
                <input
                    id="contact-email"
                    type="email"
                    name="fromEmail"
                    placeholder="jane@example.com"
                    required
                    class="font-hobeaux border border-gray-200 bg-white rounded-xl px-4 py-3 text-sm text-charcoal placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal"
                />
              </div>
            </div>

            <div class="flex flex-col gap-1">
              <label for="contact-subject" class="font-hobeaux text-charcoal text-sm font-bold">What's this about?</label>
              <select
                  id="contact-subject"
                  name="subject"
                  class="font-hobeaux border border-gray-200 bg-white rounded-xl px-4 py-3 text-sm text-charcoal focus:outline-none focus:ring-2 focus:ring-teal"
              >
                <option value="">Select a topic...</option>
                <option value="General">General Inquiry</option>
                <option value="Bulk Order">Bulk / Wholesale Order</option>
                <option value="Custom Branding">Custom Branding & Logo Treats</option>
                <option value="Events">Events & Pop-Ups</option>
                <option value="Consignment">Consignment Partnership</option>
                <option value="Birthday Cake">Birthday Cake Order</option>
                <option value="Other">Something Else</option>
              </select>
            </div>

            <div class="flex flex-col gap-1">
              <label for="contact-message" class="font-hobeaux text-charcoal text-sm font-bold">Message</label>
              <textarea
                  id="contact-message"
                  name="message[body]"
                  rows="5"
                  placeholder="Tell us what's on your mind — or share a photo of your pup. We love both."
                  required
                  class="font-hobeaux border border-gray-200 bg-white rounded-xl px-4 py-3 text-sm text-charcoal placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal resize-none"
              ></textarea>
            </div>

            <button
                type="submit"
                class="font-hobeaux bg-charcoal text-white font-bold px-8 py-3 rounded-full hover:bg-teal hover:text-charcoal transition-colors"
            >
              Send Message
            </button>

          </div>
        </form>
      </div>
      {% endif %}
    </div>

  </div>
</section>