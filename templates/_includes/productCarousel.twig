<section class="bg-white py-16 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {# Header #}
    <div class="flex items-end justify-between mb-8">
      <div>
        <p class="font-hobeaux text-teal uppercase tracking-widest text-sm mb-1">Fresh from the oven</p>
        <h2 class="font-anton text-charcoal text-4xl">Fan Favorites</h2>
      </div>
      <a href="{{ url('shop') }}" class="hidden sm:inline-block font-hobeaux text-sm text-charcoal border-b border-charcoal hover:text-teal hover:border-teal transition-colors pb-0.5">
        View All &rarr;
      </a>
    </div>

    {# Carousel Track #}
    <div class="relative">
      <div
        id="carousel-track"
        class="flex gap-6 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-4 -mx-4 px-4"
        style="scrollbar-width: none; -ms-overflow-style: none;"
      >

        {% set products = [
          {
            name: "Peanut Butter Pupcakes",
            price: "$12.00",
            tag: "Best Seller",
            img: "https://images.unsplash.com/photo-1558961363-fa8fdf82db35?w=600&q=80"
          },
          {
            name: "Sweet Potato Chews",
            price: "$9.00",
            tag: "New",
            img: "https://images.unsplash.com/photo-1601758125946-6ec2ef64daf8?w=600&q=80"
          },
          {
            name: "Carrot & Oat Biscuits",
            price: "$10.00",
            tag: "",
            img: "https://images.unsplash.com/photo-1568640347023-a616a30bc3bd?w=600&q=80"
          },
          {
            name: "Bacon Bone Cookies",
            price: "$11.00",
            tag: "Fan Fave",
            img: "https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=600&q=80"
          },
          {
            name: "Birthday Cake Bites",
            price: "$14.00",
            tag: "Limited",
            img: "https://images.unsplash.com/photo-1606313564200-e75d5e30476c?w=600&q=80"
          }
        ] %}

        {% for product in products %}
          <div class="snap-start shrink-0 w-64 sm:w-72 group">
            <div class="relative overflow-hidden rounded-2xl bg-gray-100 aspect-square mb-4">
              <img
                src="{{ product.img }}"
                alt="{{ product.name }}"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
              {% if product.tag %}
                <span class="absolute top-3 left-3 bg-teal text-charcoal font-hobeaux text-xs font-bold px-3 py-1 rounded-full">
                  {{ product.tag }}
                </span>
              {% endif %}
              <button class="absolute bottom-3 right-3 bg-white text-charcoal hover:bg-teal hover:text-white transition-colors rounded-full w-10 h-10 flex items-center justify-center shadow-md" aria-label="Add to cart">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                </svg>
              </button>
            </div>
            <h3 class="font-hobeaux font-bold text-charcoal text-base leading-snug">{{ product.name }}</h3>
            <p class="font-hobeaux text-bronze text-sm mt-1">{{ product.price }}</p>
          </div>
        {% endfor %}

      </div>

      {# Prev / Next buttons #}
      <button
        id="carousel-prev"
        class="absolute -left-4 top-1/2 -translate-y-1/2 bg-white border border-gray-200 shadow text-charcoal hover:text-teal hover:border-teal transition-colors rounded-full w-10 h-10 flex items-center justify-center z-10"
        aria-label="Previous"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button
        id="carousel-next"
        class="absolute -right-4 top-1/2 -translate-y-1/2 bg-white border border-gray-200 shadow text-charcoal hover:text-teal hover:border-teal transition-colors rounded-full w-10 h-10 flex items-center justify-center z-10"
        aria-label="Next"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>

    {# Mobile view all link #}
    <div class="sm:hidden mt-6 text-center">
      <a href="{{ url('shop') }}" class="font-hobeaux text-sm text-charcoal border-b border-charcoal hover:text-teal hover:border-teal transition-colors pb-0.5">
        View All &rarr;
      </a>
    </div>

  </div>
</section>

<script>
  const track = document.getElementById('carousel-track');
  const prev  = document.getElementById('carousel-prev');
  const next  = document.getElementById('carousel-next');
  const scrollAmount = 300;

  prev.addEventListener('click', () => track.scrollBy({ left: -scrollAmount, behavior: 'smooth' }));
  next.addEventListener('click', () => track.scrollBy({ left:  scrollAmount, behavior: 'smooth' }));
</script>
