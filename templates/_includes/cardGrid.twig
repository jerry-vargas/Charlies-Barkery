{# Set default values #}
{% set params = {
    theme: block.cardGridBlock.sectionBackgroundColor.label ?? 'white',
    eyebrowText: block.cardGridBlock.eyebrowText ?? '',
    header: block.cardGridBlock.header ?? '',
    subHeader: block.cardGridBlock.subHeader ?? '',
    cards: block.cardGridBlock.cardsMatrix.all() ?? []
}|merge(params|default({})) %}



{# Define theme-specific styling #}
{% set themes = {
    charcoal: {
        sectionBg: 'bg-charcoal',
        subheaderColor: 'text-teal',
        headerColor: 'text-white',
        descColor: 'text-white/80',
        cardBg: 'bg-white/5',
        cardBorder: 'border-white/10',
        iconWrapperClass: 'w-12 h-12 flex items-center justify-center',
        iconColor: 'text-teal',
        cardTitleColor: 'text-white',
        cardBodyColor: 'text-white/60',
        linkColor: 'text-white hover:text-teal'
    },
    bronze: {
        sectionBg: 'bg-bronze',
        subheaderColor: 'text-white/60',
        headerColor: 'text-white',
        descColor: 'text-white/70',
        cardBg: 'bg-white/10',
        cardBorder: 'border-white/20',
        iconWrapperClass: 'bg-white/20 rounded-2xl w-12 h-12 flex items-center justify-center',
        iconColor: 'text-white',
        cardTitleColor: 'text-white',
        cardBodyColor: 'text-white/70',
        linkColor: 'text-white hover:text-charcoal'
    },
    teal: {
        sectionBg: 'bg-teal',
        subheaderColor: 'text-white/70',
        headerColor: 'text-white',
        descColor: 'text-white/80',
        cardBg: 'bg-white',
        cardBorder: 'border-white/40',
        iconWrapperClass: 'bg-teal/10 rounded-2xl w-12 h-12 flex items-center justify-center',
        iconColor: 'text-teal',
        cardTitleColor: 'text-charcoal',
        cardBodyColor: 'text-charcoal/70',
        linkColor: 'text-charcoal hover:text-teal'
    },
    white: {
        sectionBg: 'bg-white',
        subheaderColor: 'text-teal',
        headerColor: 'text-charcoal',
        descColor: 'text-charcoal/70',
        cardBg: 'bg-charcoal/5',
        cardBorder: 'border-charcoal/10',
        iconWrapperClass: 'bg-teal/10 rounded-2xl w-12 h-12 flex items-center justify-center',
        iconColor: 'text-teal',
        cardTitleColor: 'text-charcoal',
        cardBodyColor: 'text-charcoal/60',
        linkColor: 'text-charcoal hover:text-teal'
    }
} %}

{% set theme = themes[params.theme|lower] %}

<section class="{{ theme.sectionBg }} py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        {# Header Section #}
        <div class="text-center mb-14">
            {% if params.eyebrowText %}
                <p class="font-hobeaux {{ theme.subheaderColor }} uppercase tracking-widest text-sm mb-2">{{ params.eyebrowText }}</p>
            {% endif %}
            <h2 class="font-anton {{ theme.headerColor }} text-4xl sm:text-5xl">{{ params.header }}</h2>
            {% if params.subHeader %}
                <p class="font-hobeaux {{ theme.descColor }} text-base leading-relaxed max-w-xl mt-4 mx-auto">{{ params.subHeader }}</p>
            {% endif %}
        </div>

        {# Cards Grid #}
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
            {% for card in params.cards %}
                <div class="{{ theme.cardBg }} border {{ theme.cardBorder }} rounded-3xl p-8 flex flex-col gap-4">

                    {# Image / Icon #}
                    {% set cardImage = card.images.one() %}
                    {% if cardImage %}
                        <div class="{{ theme.iconWrapperClass }} {{ theme.iconColor }} **:fill-current! [&_svg]:w-8 [&_svg]:h-8">
                            {% if cardImage.extension == 'svg' %}
                                {{ svg(cardImage) }}
                            {% else %}
                                <img src="{{ cardImage.url }}" alt="{{ cardImage.alt }}" class="w-8 h-8 object-contain">
                            {% endif %}
                        </div>
                    {% endif %}

                    <h3 class="font-anton {{ theme.cardTitleColor }} text-2xl">{{ card.header }}</h3>
                    <div class="font-hobeaux {{ theme.cardBodyColor }} text-sm leading-relaxed">{{ card.richTextEditor }}</div>

                    {# Optional CTA Link #}
                    {% if card.linkField.url is defined and card.linkField.url %}
                        <a href="{{ card.linkField.url }}"
                           class="font-hobeaux text-sm font-bold {{ theme.linkColor }} underline underline-offset-4 transition-colors mt-auto">
                            {{ card.linkField.label ?? card.linkField.text ?? 'Learn more' }} &rarr;
                        </a>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </div>
</section>