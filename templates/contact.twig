{% extends '_layout.twig' %}

{% block content %}
{# Page Hero #}
  {% include '_components/pageHero.twig' with {
    params:{
      img: "https://images.unsplash.com/photo-1558961363-fa8fdf82db35?w=1600&q=80",
      title: "We'd love to hear from you",
      subTitle: "Get in Touch"
    }
  } %}

{# Contact Section #}
<section class="bg-white py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-16 items-start">

    {# Left: Info #}
    <div class="flex flex-col gap-10">

      <div>
        <p class="font-hobeaux text-teal uppercase tracking-widest text-sm mb-3">Say hello</p>
        <h2 class="font-anton text-charcoal text-4xl leading-tight mb-4">We're a Small Team — We Actually Read Every Message</h2>
        <p class="font-hobeaux text-charcoal/60 text-base leading-relaxed">
          Whether you're looking to place a bulk order, plan an event, pitch a consignment deal, or just want to share a photo of your dog — we're here for all of it.
        </p>
      </div>

      {# Contact Details #}
      <div class="flex flex-col gap-6">

        <div class="flex items-start gap-4">
          <div class="bg-teal/10 rounded-2xl w-12 h-12 flex items-center justify-center shrink-0 text-xl">
            📧
          </div>
          <div>
            <p class="font-anton text-charcoal text-lg">Email</p>
            <a href="mailto:hello@charliesbarkery.com" class="font-hobeaux text-charcoal/60 text-sm hover:text-teal transition-colors">hello@charliesbarkery.com</a>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="bg-teal/10 rounded-2xl w-12 h-12 flex items-center justify-center shrink-0 text-xl">
            📍
          </div>
          <div>
            <p class="font-anton text-charcoal text-lg">Location</p>
            <p class="font-hobeaux text-charcoal/60 text-sm">Charlotte Metro Area, NC</p>
            <p class="font-hobeaux text-charcoal/40 text-xs mt-0.5">Also shipping to Massachusetts & beyond</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="bg-teal/10 rounded-2xl w-12 h-12 flex items-center justify-center shrink-0 text-xl">
            🕐
          </div>
          <div>
            <p class="font-anton text-charcoal text-lg">Response Time</p>
            <p class="font-hobeaux text-charcoal/60 text-sm">We typically reply within 1–2 business days.</p>
            <p class="font-hobeaux text-charcoal/40 text-xs mt-0.5">For urgent orders, mention it in your message.</p>
          </div>
        </div>

      </div>

      {# Socials #}
      <div>
        <p class="font-hobeaux text-charcoal/40 uppercase tracking-widest text-xs mb-3">Follow us</p>
        <div class="flex gap-4">
          <a href="https://instagram.com/charliesbarkery" target="_blank" rel="noopener" class="font-hobeaux text-sm text-charcoal/60 hover:text-teal transition-colors flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.334 3.608 1.308.975.975 1.246 2.242 1.308 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.334 2.633-1.308 3.608-.975.975-2.242 1.246-3.608 1.308-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.334-3.608-1.308-.975-.975-1.246-2.242-1.308-3.608C2.175 15.584 2.163 15.204 2.163 12s.012-3.584.07-4.85c.062-1.366.334-2.633 1.308-3.608.975-.975 2.242-1.246 3.608-1.308C8.416 2.175 8.796 2.163 12 2.163zm0-2.163C8.741 0 8.332.014 7.052.072 5.197.157 3.355.673 2.014 2.014.673 3.355.157 5.197.072 7.052.014 8.332 0 8.741 0 12c0 3.259.014 3.668.072 4.948.085 1.855.601 3.697 1.942 5.038 1.341 1.341 3.183 1.857 5.038 1.942C8.332 23.986 8.741 24 12 24s3.668-.014 4.948-.072c1.855-.085 3.697-.601 5.038-1.942 1.341-1.341 1.857-3.183 1.942-5.038.058-1.28.072-1.689.072-4.948s-.014-3.668-.072-4.948c-.085-1.855-.601-3.697-1.942-5.038C20.645.673 18.803.157 16.948.072 15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324A6.162 6.162 0 0 0 12 5.838zm0 10.162a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
            Instagram
          </a>
          <a href="https://facebook.com/charliesbarkery" target="_blank" rel="noopener" class="font-hobeaux text-sm text-charcoal/60 hover:text-teal transition-colors flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
            Facebook
          </a>
        </div>
      </div>

    </div>

    {# Right: Form #}
    <div class="bg-gray-50 rounded-3xl p-8">
      <h3 class="font-anton text-charcoal text-2xl mb-6">Send Us a Message</h3>
      <form method="post" accept-charset="UTF-8" novalidate>
        {{ csrfInput() }}
        <input type="hidden" name="action" value="contact-form/send">

        <div class="flex flex-col gap-5">

          <div class="grid sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1">
              <label for="contact-name" class="font-hobeaux text-charcoal text-sm font-bold">Your Name</label>
              <input
                id="contact-name"
                type="text"
                name="fromName"
                placeholder="Jane Smith"
                required
                class="font-hobeaux border border-gray-200 bg-white rounded-xl px-4 py-3 text-sm text-charcoal placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal"
              />
            </div>
            <div class="flex flex-col gap-1">
              <label for="contact-email" class="font-hobeaux text-charcoal text-sm font-bold">Email Address</label>
              <input
                id="contact-email"
                type="email"
                name="fromEmail"
                placeholder="jane@example.com"
                required
                class="font-hobeaux border border-gray-200 bg-white rounded-xl px-4 py-3 text-sm text-charcoal placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal"
              />
            </div>
          </div>

          <div class="flex flex-col gap-1">
            <label for="contact-subject" class="font-hobeaux text-charcoal text-sm font-bold">What's this about?</label>
            <select
              id="contact-subject"
              name="subject"
              class="font-hobeaux border border-gray-200 bg-white rounded-xl px-4 py-3 text-sm text-charcoal focus:outline-none focus:ring-2 focus:ring-teal"
            >
              <option value="">Select a topic...</option>
              <option value="General">General Inquiry</option>
              <option value="Bulk Order">Bulk / Wholesale Order</option>
              <option value="Custom Branding">Custom Branding & Logo Treats</option>
              <option value="Events">Events & Pop-Ups</option>
              <option value="Consignment">Consignment Partnership</option>
              <option value="Birthday Cake">Birthday Cake Order</option>
              <option value="Other">Something Else</option>
            </select>
          </div>

          <div class="flex flex-col gap-1">
            <label for="contact-message" class="font-hobeaux text-charcoal text-sm font-bold">Message</label>
            <textarea
              id="contact-message"
              name="message[body]"
              rows="5"
              placeholder="Tell us what's on your mind — or share a photo of your pup. We love both."
              required
              class="font-hobeaux border border-gray-200 bg-white rounded-xl px-4 py-3 text-sm text-charcoal placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="font-hobeaux bg-charcoal text-white font-bold px-8 py-3 rounded-full hover:bg-teal hover:text-charcoal transition-colors"
          >
            Send Message
          </button>

        </div>
      </form>
    </div>
  </div>
</section>

{% endblock %}