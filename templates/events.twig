{% extends '_layout.twig' %}

{% block content %}

  {% include '_components/pageHero.twig' with {
    params: {
      img: "https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=1600&q=80",
      title: "Come Find Us",
      subTitle: "Events & Markets"
    }
  } %}

  {# Intro #}
  <section class="bg-white py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-hobeaux text-teal uppercase tracking-widest text-sm mb-2">We get around</p>
      <h2 class="font-anton text-charcoal text-4xl sm:text-5xl mb-4">Where We'll Be Next</h2>
      <p class="font-hobeaux text-charcoal/60 text-base leading-relaxed">
        We love getting out in the community — farmers markets, dog-friendly festivals, pop-ups, and more. Come say hi, bring your dog, and let them pick their own treat.
      </p>
    </div>
  </section>

  {# Upcoming Events #}
  <section class="bg-gray-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <h3 class="font-anton text-charcoal text-3xl mb-8">Upcoming Events</h3>

      <div class="flex flex-col gap-6">

        {% set events = [
          {
            date: "Apr 5, 2026",
            day: "Sun",
            name: "Matthews Community Farmers Market",
            type: "Farmers Market",
            location: "Matthews, NC",
            time: "8:00 AM – 12:00 PM",
            note: "We'll have the full spring lineup plus a limited batch of birthday cakes."
          },
          {
            date: "Apr 12, 2026",
            day: "Sat",
            name: "Bark in the Park — Freedom Park",
            type: "Dog Festival",
            location: "Charlotte, NC",
            time: "10:00 AM – 4:00 PM",
            note: "One of our favorite events of the year. Bring your pup — there will be samples!"
          },
          {
            date: "Apr 19, 2026",
            day: "Sat",
            name: "South End Farmers Market",
            type: "Farmers Market",
            location: "Charlotte, NC",
            time: "9:00 AM – 1:00 PM",
            note: ""
          },
          {
            date: "May 3, 2026",
            day: "Sat",
            name: "Paws & Pints — NoDa Brewing",
            type: "Pop-Up",
            location: "Charlotte, NC",
            time: "12:00 PM – 5:00 PM",
            note: "Dog-friendly brewery pop-up. Treats for the pups, cold drinks for the humans."
          },
          {
            date: "May 17, 2026",
            day: "Sun",
            name: "Waxhaw Farmers Market",
            type: "Farmers Market",
            location: "Waxhaw, NC",
            time: "8:00 AM – 12:00 PM",
            note: ""
          }
        ] %}

        {% for event in events %}
          <div class="bg-white rounded-3xl p-6 flex flex-col sm:flex-row gap-6 items-start sm:items-center border border-gray-100 hover:border-teal transition-colors group">

            {# Date Badge #}
            <div class="bg-charcoal group-hover:bg-teal transition-colors rounded-2xl px-5 py-4 text-center shrink-0 min-w-[72px]">
              <p class="font-hobeaux text-white/60 text-xs uppercase tracking-widest">{{ event.day }}</p>
              <p class="font-anton text-white text-2xl leading-tight">{{ event.date|split(' ')[1] }}</p>
              <p class="font-hobeaux text-white/60 text-xs">{{ event.date|split(' ')[0] }}</p>
            </div>

            {# Details #}
            <div class="flex flex-col gap-1 grow">
              <div class="flex flex-wrap items-center gap-2">
                <h4 class="font-anton text-charcoal text-xl">{{ event.name }}</h4>
                <span class="font-hobeaux text-xs bg-teal/10 text-teal px-3 py-0.5 rounded-full">{{ event.type }}</span>
              </div>
              <div class="flex flex-wrap gap-4 font-hobeaux text-sm text-charcoal/50 mt-1">
                <span class="flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  {{ event.location }}
                </span>
                <span class="flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  {{ event.time }}
                </span>
              </div>
              {% if event.note %}
                <p class="font-hobeaux text-sm text-charcoal/50 mt-1 italic">{{ event.note }}</p>
              {% endif %}
            </div>

            {# Arrow #}
            <div class="text-charcoal/20 group-hover:text-teal transition-colors shrink-0 hidden sm:block">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </div>

          </div>
        {% endfor %}

      </div>
    </div>
  </section>

  {# Regular Markets #}
  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-12 items-center">

      <div>
        <img
          src="https://images.unsplash.com/photo-1601758125946-6ec2ef64daf8?w=800&q=80"
          alt="Charlie's Barkery at a farmers market"
          class="rounded-3xl w-full h-[400px] object-cover"
        />
      </div>

      <div class="flex flex-col gap-5">
        <p class="font-hobeaux text-teal uppercase tracking-widest text-sm">Our regulars</p>
        <h2 class="font-anton text-charcoal text-4xl leading-tight">Markets We Attend Year-Round</h2>
        <p class="font-hobeaux text-charcoal/60 text-base leading-relaxed">
          Outside of special events, you can usually find us at these recurring markets throughout the Charlotte Metro Area. Check our Instagram for week-to-week updates.
        </p>
        <ul class="flex flex-col gap-3 font-hobeaux text-sm text-charcoal/70">
          <li class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-teal shrink-0"></span>
            <span><strong class="text-charcoal">Matthews Community Farmers Market</strong> — Sundays, year-round</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-teal shrink-0"></span>
            <span><strong class="text-charcoal">South End Farmers Market</strong> — Saturdays, seasonal</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-teal shrink-0"></span>
            <span><strong class="text-charcoal">Waxhaw Farmers Market</strong> — Sundays, seasonal</span>
          </li>
        </ul>
        <a
          href="https://instagram.com/charliesbarkery"
          target="_blank"
          rel="noopener"
          class="font-hobeaux font-bold bg-charcoal text-white px-8 py-3 rounded-full hover:bg-teal hover:text-charcoal transition-colors self-start mt-2"
        >
          Follow for Updates
        </a>
      </div>

    </div>
  </section>

  {# Book Us Banner #}
  <section class="bg-bronze py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-8">
      <div>
        <h2 class="font-anton text-white text-4xl sm:text-5xl leading-tight">Want Us at Your Event?</h2>
        <p class="font-hobeaux text-white/70 text-base mt-3 max-w-xl leading-relaxed">
          We do dog-friendly festivals, corporate pop-ups, adoption events, brewery days, and more. If there are dogs involved, we're in.
        </p>
      </div>
      <a
        href="{{ url('contact') }}?subject=Events"
        class="font-hobeaux font-bold bg-white text-bronze px-10 py-4 rounded-full hover:bg-charcoal hover:text-white transition-colors shrink-0 text-lg"
      >
        Book Us
      </a>
    </div>
  </section>

{% endblock %}
